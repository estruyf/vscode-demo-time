{
  "$schema": "https://beta.demotime.show/gallery/snippet.schema.json",
  "id": "setup/presentation-clean-up-macos",
  "name": "Presentation clean-up",
  "description": "Restores VS Code to its original state after a presentation: disables Caffeine, shows the menubar, switches back to the original theme, exits full screen, and shows the activity bar and title bar.",
  "author": "Elio Struyf",
  "version": "1.0.0",
  "tags": ["setup", "macos", "presentation"],
  "fields": [
    {
      "name": "THEME",
      "description": "The VS Code theme to switch to after the presentation",
      "type": "string",
      "required": false,
      "default": "Demo Time Light"
    }
  ],
  "steps": [
    {
      "action": "macos.disableCaffeine"
    },
    {
      "action": "macos.showMenubar"
    },
    {
      "action": "setTheme",
      "theme": "{THEME}"
    },
    {
      "action": "executeVSCodeCommand",
      "command": "workbench.action.activityBarLocation.default"
    },
    {
      "action": "executeVSCodeCommand",
      "command": "showCustomTitleBar"
    },
    {
      "action": "executeVSCodeCommand",
      "command": "workbench.action.toggleFullScreen"
    }
  ]
}
